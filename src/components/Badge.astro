---
interface Props {
  variant?: 'default' | 'success' | 'danger' | 'purple' | 'muted' | 'eva00' | 'eva01' | 'eva02';
}
const { variant = 'default' } = Astro.props;
---
<span class={`badge badge--${variant}`}><slot /></span>

<style>
  .badge {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-panel);
    border: 1px solid currentColor;
    text-transform: uppercase;
  }

  .badge--default { color: var(--color-nerv-green); }
  .badge--success { color: var(--color-nerv-green); }
  .badge--danger { color: var(--color-alert-red); }
  .badge--purple { color: var(--color-nerv-purple-bright); }
  .badge--muted { color: var(--color-text-muted); }
  .badge--eva00 { color: var(--color-eva00); }
  .badge--eva01 { color: var(--color-eva01); }
  .badge--eva02 { color: var(--color-eva02); }
</style>
