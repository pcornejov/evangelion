---
import { withBase } from '../utils/url';

interface Props {
  href: string;
  title: string;
  subtitle?: string;
  image?: string;
}
const { href, title, subtitle, image } = Astro.props;
---
<a class="card" href={withBase(href)}>
  {image && <img src={withBase(image)} alt={title} loading="lazy" />}
  <div class="card-body">
    <h3>{title}</h3>
    {subtitle && <p>{subtitle}</p>}
    <slot />
  </div>
</a>

<style>
  .card {
    display: block;
    background: var(--color-bg-panel);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-panel);
    overflow: hidden;
    color: var(--color-text);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .card:hover {
    border-color: var(--color-nerv-green);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    background: var(--color-bg-panel-alt);
  }

  .card-body {
    padding: var(--space-sm);
  }

  .card-body h3 {
    margin: 0 0 0.25rem;
    font-size: 1rem;
  }

  .card-body p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }
</style>
