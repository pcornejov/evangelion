---
import { withBase } from '../utils/url';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  crumbs: Crumb[];
}
const { crumbs } = Astro.props;
---
<nav class="breadcrumbs" aria-label="Breadcrumb">
  {crumbs.map((crumb, i) => (
    <>
      {i > 0 && <span class="sep">/</span>}
      {crumb.href ? <a href={withBase(crumb.href)}>{crumb.label}</a> : <span>{crumb.label}</span>}
    </>
  ))}
</nav>

<style>
  .breadcrumbs {
    font-family: var(--font-display);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .sep {
    margin: 0 0.4rem;
  }
</style>
