---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntityGrid from '../../components/EntityGrid.astro';
import Card from '../../components/Card.astro';
import { getCollection } from 'astro:content';

const mechas = await getCollection('mechas');
---
<BaseLayout title="Mechas — NERV Encyclopedia">
  <main>
    <h1>Mechas</h1>
    {mechas.length === 0 ? (
      <p>Sección en construcción. Próximamente.</p>
    ) : (
      <EntityGrid>
        {mechas.map((m) => (
          <Card href={`/mechas/${m.id}`} title={m.data.unitName} subtitle={m.data.unitDesignation} image={m.data.image} />
        ))}
      </EntityGrid>
    )}
  </main>
</BaseLayout>
